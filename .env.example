# Copy this file to .env and fill in real values
# Never commit .env to git

# OneTimeSecret API credentials (required)
# Get your credentials at: https://onetimesecret.com/account
OTS_USER=your-email@example.com
OTS_KEY=your-api-key-here

# OneTimeSecret API host (optional - defaults to onetimesecret.com)
OTS_HOST=https://onetimesecret.com/api

# Server config (optional - defaults shown)
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# CORS allowed origin (optional - leave empty to disable CORS)
# CORS_ORIGIN=https://your-frontend.com
